<style>
  header .plate-wrap { filter: none; }

  .retro-drop {
    background: rgba(11, 43, 26, 0.95);
    backdrop-filter: blur(20px) saturate(1.3);
    border: 1px solid rgba(0, 232, 143, 0.25);
    border-radius: 4px;
    padding: 4px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.4), 0 0 12px rgba(0,232,143,0.1);
  }
  .retro-drop a {
    display: block;
    padding: 7px 16px 7px 12px;
    font-family: 'Press Start 2P', monospace;
    font-size: 7px;
    line-height: 2;
    color: rgba(245,240,230,0.55);
    text-decoration: none;
    border-radius: 2px;
    white-space: nowrap;
    transition: color 80ms ease, background 80ms ease;
  }
  .retro-drop a:hover {
    color: #00e88f;
    background: rgba(0,232,143,0.08);
  }
  .retro-drop-divider {
    height: 1px;
    margin: 3px 8px;
    background: rgba(0,232,143,0.12);
  }
</style>

<div x-data="{ mobileMenuOpen: false, tOpen: false }" class="contents"
  @keydown.escape.window="tOpen = false"
  @scroll.window="tOpen = false"
  @click.window="if(!$event.target.closest('[data-tetra-nav]')) tOpen = false">

<header class="fixed top-0 left-0 right-0 z-50">
  <div class="pt-4 md:pt-6 px-4 md:px-6 pointer-events-none">
  <div class="max-w-6xl mx-auto">
    <div class="plate-wrap relative">
      <div class="plate chamfer-full md:chamfer-full-lg px-4 md:px-6 py-3 md:py-4 pointer-events-auto relative">
        <div class="rivet absolute top-1/2 left-7 -translate-y-1/2 z-20"></div>
        <div class="rivet absolute top-1/2 right-7 -translate-y-1/2 z-20"></div>

        <!-- Desktop -->
        <div class="hidden md:flex items-center">
          <div class="flex-1 flex items-center justify-end gap-8 pr-8">
            <a href="{{ '/tetra/' | url }}"
              x-ref="tetraBtn"
              data-tetra-nav
              @click.prevent="tOpen = !tOpen"
              class="font-arcade text-[9px] hover:scale-[1.18] transition-all duration-200 origin-center inline-flex items-center gap-1"
              style="color: #00e88f; text-shadow: 0 0 6px rgba(0,232,143,0.3);">
              TETRA
              <svg class="w-2.5 h-2.5 transition-transform duration-150" :class="tOpen && 'rotate-180'" viewBox="0 0 22 22" fill="none" stroke="currentColor"><path d="M18 7L11 14L4 7" stroke-width="2"></path></svg>
            </a>
            <a href="{{ '/profile/' | url }}" class="font-display font-bold text-cream-100 hover:text-morpho-400 transition-all duration-200 md:text-lg hover:scale-[1.18] origin-center inline-block">Work</a>
            <a href="{{ '/about/' | url }}" class="font-display font-bold text-cream-100 hover:text-morpho-400 transition-all duration-200 md:text-lg hover:scale-[1.18] origin-center inline-block">About</a>
          </div>

          <a href="{{ '/' | url }}" class="flex-shrink-0 hover:scale-[1.18] transition-all duration-200 origin-center inline-block [&_img]:transition-all [&_img]:duration-200 [&_img]:hover:brightness-125 hover:[filter:drop-shadow(0_0_10px_#2A95C8)_drop-shadow(0_0_20px_#2A95C880)]">
            {% image "./src/static/corewood_symbol_transparent_ON-DARK.png", "Corewood", "56px", "h-14", "56", "eager" %}
          </a>

          <div class="flex-1 flex items-center justify-start gap-8 pl-8 pr-[40px]">
            <a href="{{ '/blog/' | url }}" class="font-display font-bold text-cream-100 hover:text-morpho-400 transition-all duration-200 md:text-lg hover:scale-[1.18] origin-center inline-block">Blog</a>
            <a href="{{ '/contact/' | url }}" class="font-display font-bold text-cream-100 hover:text-morpho-400 transition-all duration-200 md:text-lg hover:scale-[1.18] origin-center inline-block">Contact</a>
            <span class="flex-1"></span>
            <a href="{{ '/schedule-meeting/' | url }}" class="btn-primary text-xs px-4 py-2 flex-shrink-0">Schedule a Meeting</a>
          </div>
        </div>

        <!-- Mobile -->
        <div class="flex md:hidden items-center justify-center relative">
          <button @click="mobileMenuOpen = !mobileMenuOpen" class="absolute left-[25%] -translate-x-1/2 p-2 text-cream-200 hover:text-morpho-400 focus:outline-none" aria-label="Toggle menu">
            <svg x-show="!mobileMenuOpen" class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
            <svg x-show="mobileMenuOpen" x-cloak class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="m18 6-12 12"/><path d="m6 6 12 12"/></svg>
          </button>
          <a href="{{ '/' | url }}">{% image "./src/static/corewood_symbol_transparent_ON-DARK.png", "Corewood", "40px", "h-10", "40", "eager" %}</a>
          <a href="{{ '/schedule-meeting/' | url }}" class="absolute right-[25%] translate-x-1/2 btn-primary text-[10px] px-3 py-1.5">Book</a>
        </div>
      </div>
    </div>
  </div>
  </div>

  <!-- Mobile menu -->
  <div x-show="mobileMenuOpen" x-cloak
    x-transition:enter="transition ease-out duration-200" x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100"
    x-transition:leave="transition ease-in duration-150" x-transition:leave-start="opacity-100" x-transition:leave-end="opacity-0"
    class="md:hidden max-w-6xl mx-auto mt-4 pointer-events-auto px-4">
    <div class="plate-wrap">
      <div class="plate chamfer-full p-8">
        <nav class="flex flex-col items-center space-y-6">
          <a href="{{ '/tetra/' | url }}" @click="mobileMenuOpen = false" class="font-arcade text-sm hover:text-[#00e88f] transition-colors" style="color: #00e88f; text-shadow: 0 0 6px rgba(0,232,143,0.3);">TETRA</a>
          <div class="flex flex-col items-center gap-3 -mt-2">
            <a href="{{ '/tetra/vs-neo4j/' | url }}" @click="mobileMenuOpen = false" class="font-arcade text-[7px] text-cream-500 hover:text-[#00e88f] transition-colors leading-[2]">VS NEO4J</a>
            <a href="{{ '/tetra/ai/' | url }}" @click="mobileMenuOpen = false" class="font-arcade text-[7px] text-cream-500 hover:text-[#00e88f] transition-colors leading-[2]">FOR AI</a>
            <a href="{{ '/tetra/startups/' | url }}" @click="mobileMenuOpen = false" class="font-arcade text-[7px] text-cream-500 hover:text-[#00e88f] transition-colors leading-[2]">STARTUPS</a>
            <a href="{{ '/tetra/edge/' | url }}" @click="mobileMenuOpen = false" class="font-arcade text-[7px] text-cream-500 hover:text-[#00e88f] transition-colors leading-[2]">EDGE</a>
          </div>
          <a href="{{ '/profile/' | url }}" @click="mobileMenuOpen = false" class="text-xl text-cream-100 hover:text-morpho-400 transition-colors">Work</a>
          <a href="{{ '/about/' | url }}" @click="mobileMenuOpen = false" class="text-xl text-cream-100 hover:text-morpho-400 transition-colors">About</a>
          <a href="{{ '/blog/' | url }}" @click="mobileMenuOpen = false" class="text-xl text-cream-100 hover:text-morpho-400 transition-colors">Blog</a>
          <a href="{{ '/contact/' | url }}" @click="mobileMenuOpen = false" class="text-xl text-cream-100 hover:text-morpho-400 transition-colors">Contact</a>
          <a href="{{ '/schedule-meeting/' | url }}" @click="mobileMenuOpen = false" class="btn-primary text-center mt-2">Schedule a Meeting</a>
        </nav>
      </div>
    </div>
  </div>
</header>

<!-- TETRA dropdown — OUTSIDE header so it's in the root stacking context -->
<div x-show="tOpen" x-cloak
  x-transition:enter="transition ease-out duration-150"
  x-transition:enter-start="opacity-0 -translate-y-1"
  x-transition:enter-end="opacity-100 translate-y-0"
  x-transition:leave="transition ease-in duration-100"
  x-transition:leave-start="opacity-100"
  x-transition:leave-end="opacity-0"
  data-tetra-nav
  class="fixed z-[9998] hidden md:block"
  :style="`top: ${$refs.tetraBtn.getBoundingClientRect().bottom + 8}px; left: ${$refs.tetraBtn.getBoundingClientRect().left}px`">
  <div class="retro-drop">
    <a href="{{ '/tetra/' | url }}">&#9654; OVERVIEW</a>
    <div class="retro-drop-divider"></div>
    <a href="{{ '/tetra/vs-neo4j/' | url }}">&#9654; VS NEO4J</a>
    <a href="{{ '/tetra/ai/' | url }}">&#9654; FOR AI</a>
    <a href="{{ '/tetra/startups/' | url }}">&#9654; STARTUPS</a>
    <a href="{{ '/tetra/edge/' | url }}">&#9654; EDGE</a>
    <div class="retro-drop-divider"></div>
    <a href="{{ '/tetra-demo/' | url }}">&#9654; PLAY DEMO</a>
  </div>
</div>

</div>
