{# ── CRT scanline overlay ── #}
<div class="crt-overlay"></div>

<section id="hero" class="relative min-h-screen flex flex-col items-center justify-center overflow-hidden">

  <!-- Content -->
  <div class="relative z-10 w-full max-w-4xl mx-auto px-4 md:px-6 pt-28 md:pt-32 pb-16 md:pb-24">
    <div class="plate-wrap">
      <div class="plate chamfer-full-lg p-10 md:p-16 text-center">
        <div class="rivet absolute top-7 left-7 z-10"></div>
        <div class="rivet absolute top-7 right-7 z-10"></div>
        <div class="rivet absolute bottom-7 left-7 z-10"></div>
        <div class="rivet absolute bottom-7 right-7 z-10"></div>

        <!-- TETRA logo -->
        <img src="{{ '/tetra-logo.svg' | url }}" alt="TETRA" class="w-[200px] md:w-[280px] h-auto mb-6 mx-auto" style="filter: drop-shadow(0 0 30px rgba(0, 232, 143, 0.15));" />

        <!-- Headline -->
        <h1 id="hero-title" class="opacity-0 transition-opacity duration-1000 ease-out">
          <span class="block font-arcade text-xl sm:text-2xl md:text-3xl lg:text-4xl leading-[2] tetra-rainbow" style="text-shadow: none;">The graph database, rethought.</span>
          <span class="block mt-4 font-display font-light text-base sm:text-xl md:text-2xl tracking-wide text-cream-300">
            <span id="hero-left" class="inline-block transition-all duration-700 ease-out translate-x-[-30vw] opacity-0">Faster.</span>
            <span id="hero-dot" class="inline-block mx-1 md:mx-4 text-cream-600 opacity-0 transition-opacity duration-500 ease-out">&middot;</span>
            <span id="hero-right" class="inline-block transition-all duration-700 ease-out translate-x-[30vw] opacity-0">Smaller.</span>
            <span id="hero-dot2" class="inline-block mx-1 md:mx-4 text-cream-600 opacity-0 transition-opacity duration-500 ease-out">&middot;</span>
            <span id="hero-extra" class="inline-block transition-all duration-700 ease-out opacity-0">A fraction of the cost.</span>
          </span>
        </h1>

        <!-- Lead paragraph -->
        <p class="text-cream-300 text-sm md:text-base leading-relaxed max-w-3xl mx-auto mt-8 mb-10">
          172 million edges from a single 3.6 GB file. 14/14 LDBC Interactive Complex queries at SF10 scale. <strong class="text-cream-100">10&times; less RAM</strong> than the industry standard. Full openCypher, full Bolt protocol, <strong class="text-cream-100">$299/month flat</strong>. No per-GB scaling. No cluster required.
        </p>

        <!-- Comparative stats -->
        <div class="max-w-xl mx-auto mb-10">
          {# Header row #}
          <div class="grid grid-cols-[2fr_1fr_1fr] gap-0 items-center pb-2 border-b border-cream-100/10">
            <div></div>
            <div class="font-arcade text-[7px] md:text-[8px] uppercase tracking-wider text-center" style="color: #00e88f;">TETRA</div>
            <div class="font-arcade text-[7px] md:text-[8px] uppercase tracking-wider text-center text-cream-600">Neo4j</div>
          </div>

          {# RAM row #}
          <div class="grid grid-cols-[2fr_1fr_1fr] gap-0 items-center border-b border-cream-100/5 py-3">
            <div class="font-arcade text-[6px] md:text-[7px] text-cream-500 text-left pl-2 leading-[2]">RAM used</div>
            <div class="font-arcade text-sm md:text-base text-center arcade-glow" style="color: #00e88f;">66 MB</div>
            <div class="font-arcade text-sm md:text-base text-center text-cream-600">710 MB</div>
          </div>

          {# Writes row #}
          <div class="grid grid-cols-[2fr_1fr_1fr] gap-0 items-center border-b border-cream-100/5 py-3">
            <div class="font-arcade text-[6px] md:text-[7px] text-cream-500 text-left pl-2 leading-[2]">Writes completed</div>
            <div class="font-arcade text-sm md:text-base text-center arcade-glow" style="color: #00e88f;">11/11</div>
            <div class="font-arcade text-sm md:text-base text-center" style="color: #e85454;">0/11 <span class="text-[5px] text-cream-700 block leading-[2]">OOM</span></div>
          </div>

          {# Cost row #}
          <div class="grid grid-cols-[2fr_1fr_1fr] gap-0 items-center border-b border-cream-100/5 py-3">
            <div class="font-arcade text-[6px] md:text-[7px] text-cream-500 text-left pl-2 leading-[2]">Monthly (16 GB)</div>
            <div class="font-arcade text-sm md:text-base text-center arcade-glow" style="color: #00e88f;">$299</div>
            <div class="font-arcade text-sm md:text-base text-center text-cream-600">$1,051</div>
          </div>

          {# LDBC row #}
          <div class="grid grid-cols-[2fr_1fr_1fr] gap-0 items-center border-b border-cream-100/10 py-3">
            <div class="font-arcade text-[6px] md:text-[7px] text-cream-500 text-left pl-2 leading-[2]">LDBC SF10</div>
            <div class="font-arcade text-[10px] md:text-xs text-center arcade-glow" style="color: #00e88f;">14/14 &middot; 405ms</div>
            <div class="font-arcade text-[10px] md:text-xs text-center" style="color: #e85454;">Fails</div>
          </div>
        </div>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row items-center justify-center gap-3 sm:gap-5">
          <a href="{{ '/tetra/' | url }}" class="btn-primary text-center w-full sm:w-auto">
            <span class="block text-sm md:text-base font-medium">See the Benchmarks &rarr;</span>
          </a>
          <a href="{{ '/schedule-meeting/' | url }}" class="btn-secondary text-center w-full sm:w-auto">
            <span class="block text-sm md:text-base font-medium">Schedule a Migration Call</span>
          </a>
        </div>

      </div>
    </div>
  </div>

</section>
